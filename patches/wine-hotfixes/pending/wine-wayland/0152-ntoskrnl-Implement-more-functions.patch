From 7897945b3fb53866f5100bf135eb70be810fa92b Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Mon, 23 Jun 2025 15:56:57 -0400
Subject: [PATCH 152/163] ntoskrnl: Implement more functions.

---
 dlls/ntoskrnl.exe/ntoskrnl.c        | 34 +++++++++++++++++++++++++++--
 dlls/ntoskrnl.exe/ntoskrnl.exe.spec |  4 ++--
 2 files changed, 34 insertions(+), 4 deletions(-)

diff --git a/dlls/ntoskrnl.exe/ntoskrnl.c b/dlls/ntoskrnl.exe/ntoskrnl.c
index f4ddb355cb5..a1035526e25 100644
--- a/dlls/ntoskrnl.exe/ntoskrnl.c
+++ b/dlls/ntoskrnl.exe/ntoskrnl.c
@@ -2534,6 +2534,14 @@ HANDLE WINAPI PsGetProcessId(PEPROCESS process)
     return (HANDLE)process->info.UniqueProcessId;
 }
 
+/*********************************************************************
+ *           PsGetProcessPeb    (NTOSKRNL.@)
+ */
+PEB *WINAPI PsGetProcessPeb(PEPROCESS process)
+{
+    return process->info.PebBaseAddress;
+}
+
 /*********************************************************************
  *           PsGetProcessInheritedFromUniqueProcessId  (NTOSKRNL.@)
  */
@@ -2552,6 +2560,14 @@ NTSTATUS WINAPI PsGetProcessExitStatus( PEPROCESS process )
     return process->info.ExitStatus;
 }
 
+/*********************************************************************
+ *           PsGetProcessExitProcessCalled    (NTOSKRNL.@)
+ */
+BOOL WINAPI PsGetProcessExitProcessCalled(PEPROCESS process)
+{
+    return PsGetProcessExitStatus(process) != STILL_ACTIVE;
+}
+
 /*********************************************************************
  *           PsGetProcessSessionId    (NTOSKRNL.@)
  */
@@ -3880,7 +3896,7 @@ BOOLEAN WINAPI KeRegisterBugCheckReasonCallback(KBUGCHECK_REASON_CALLBACK_RECORD
  */
 NTSTATUS WINAPI SeQueryInformationToken(PACCESS_TOKEN token, TOKEN_INFORMATION_CLASS class, void *out)
 {
-    FIXME("%p %x %p\n", token, class, out);
+    FIXME("%p %#x %p stub!\n", token, class, out);
 
     return STATUS_NOT_IMPLEMENTED;
 }
@@ -3898,7 +3914,21 @@ void WINAPI ProbeForRead(void *address, SIZE_T length, ULONG alignment)
  */
 void WINAPI ProbeForWrite(void *address, SIZE_T length, ULONG alignment)
 {
-    FIXME("(%p %Iu %lu) stub\n", address, length, alignment);
+    volatile char *ptr = address; /* prevent optimization */
+    FIXME("(%p %Iu %lu)\n", address, length, alignment);
+
+    /* FIXME: is my math right? */
+    if ((ULONG_PTR)address & (alignment-1))
+        RtlRaiseStatus(STATUS_DATATYPE_MISALIGNMENT);
+
+    /*
+       check if the data is writeable
+       Will emit access violation if it's not :)
+    */
+    for (SIZE_T i = 0; i < length; i++)
+    {
+        ptr[i] |= 0;
+    }
 }
 
 /***********************************************************************
diff --git a/dlls/ntoskrnl.exe/ntoskrnl.exe.spec b/dlls/ntoskrnl.exe/ntoskrnl.exe.spec
index 512345c2fea..e9646b93b80 100644
--- a/dlls/ntoskrnl.exe/ntoskrnl.exe.spec
+++ b/dlls/ntoskrnl.exe/ntoskrnl.exe.spec
@@ -924,14 +924,14 @@
 @ stub PsGetJobUIRestrictionsClass
 @ stdcall PsGetProcessCreateTimeQuadPart(ptr)
 @ stub PsGetProcessDebugPort
-@ stub PsGetProcessExitProcessCalled
+@ stdcall PsGetProcessExitProcessCalled(ptr)
 @ stdcall PsGetProcessExitStatus(ptr)
 @ stub PsGetProcessExitTime
 @ stdcall PsGetProcessId(ptr)
 @ stdcall PsGetProcessImageFileName(ptr)
 @ stdcall PsGetProcessInheritedFromUniqueProcessId(ptr)
 @ stub PsGetProcessJob
-@ stub PsGetProcessPeb
+@ stdcall PsGetProcessPeb(ptr)
 @ stub PsGetProcessPriorityClass
 @ stdcall PsGetProcessSectionBaseAddress(ptr)
 @ stub PsGetProcessSecurityPort
