From 0df4c9c016caf8e5c9c653197857bf3a58612900 Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Tue, 24 Jun 2025 23:13:38 -0400
Subject: [PATCH 157/163] ntoskrnl: Implement some token related methods.

---
 dlls/ntoskrnl.exe/ntoskrnl.c         | 63 +++++++++++++++++++++++-----
 dlls/ntoskrnl.exe/ntoskrnl_private.h |  1 +
 include/winnt.h                      |  9 +++-
 3 files changed, 61 insertions(+), 12 deletions(-)

diff --git a/dlls/ntoskrnl.exe/ntoskrnl.c b/dlls/ntoskrnl.exe/ntoskrnl.c
index 60b29497653..2c538bf25e6 100644
--- a/dlls/ntoskrnl.exe/ntoskrnl.c
+++ b/dlls/ntoskrnl.exe/ntoskrnl.c
@@ -2461,12 +2461,23 @@ NTSTATUS WINAPI FsRtlRegisterUncProvider(PHANDLE MupHandle, PUNICODE_STRING Redi
     return STATUS_NOT_IMPLEMENTED;
 }
 
+static void *create_token_object( HANDLE handle )
+{
+    TOKEN *token;
+
+    if (!(token = alloc_kernel_object( SeTokenObjectType, handle, sizeof(*token), 0 ))) return NULL;
+
+    token->handle = handle;
+
+    return token;
+}
 
 static void *create_process_object( HANDLE handle )
 {
     PEPROCESS process;
     UNICODE_STRING imageName;
     ANSI_STRING imageNameA;
+    HANDLE token;
 
     if (!(process = alloc_kernel_object( PsProcessType, handle, sizeof(*process), 0 ))) return NULL;
 
@@ -2484,6 +2495,10 @@ static void *create_process_object( HANDLE handle )
     RtlFreeAnsiString(&imageNameA);
 
     IsWow64Process( handle, &process->wow64 );
+
+    NtOpenProcessToken( handle, TOKEN_ALL_ACCESS, &token );
+    process->token = create_token_object( token );
+
     return process;
 }
 
@@ -2584,11 +2599,14 @@ LONGLONG WINAPI PsGetProcessCreateTimeQuadPart( PEPROCESS process )
     return process->times.CreateTime.QuadPart;
 }
 
+/*********************************************************************
+ *           PsReferencePrimaryToken    (NTOSKRNL.@)
+ */
 PACCESS_TOKEN WINAPI PsReferencePrimaryToken( PEPROCESS process )
 {
-    static char token[0x200];
-    FIXME("%p stub!\n", process);
-    return token + 0x50;
+    TRACE("%p\n", process);
+    ObReferenceObject(process->token);
+    return process->token;
 }
 
 static void *create_thread_object( HANDLE handle )
@@ -2993,9 +3011,18 @@ NTSTATUS WINAPI MmCreateSection( HANDLE *handle, ACCESS_MASK access, OBJECT_ATTR
                                  LARGE_INTEGER *size, ULONG protect, ULONG alloc_attr,
                                  HANDLE file, FILE_OBJECT *file_obj )
 {
-    FIXME("%p %#lx %p %s %#lx %#lx %p %p: stub\n", handle, access, attr,
+    NTSTATUS status;
+    TRACE("%p %#lx %p %s %#lx %#lx %p %p\n", handle, access, attr,
         wine_dbgstr_longlong(size->QuadPart), protect, alloc_attr, file, file_obj);
-    return STATUS_NOT_IMPLEMENTED;
+
+    status = NtCreateSection( handle, access, attr, size, protect, alloc_attr, file );
+
+    if (status) return status;
+
+    /* FIXME: is this correct? */
+    file_obj = create_file_object(*handle);
+
+    return STATUS_SUCCESS;
 }
 
 /***********************************************************************
@@ -3902,11 +3929,20 @@ BOOLEAN WINAPI KeRegisterBugCheckReasonCallback(KBUGCHECK_REASON_CALLBACK_RECORD
 /***********************************************************************
  *           SeQueryInformationToken    (NTOSKRNL.@)
  */
-NTSTATUS WINAPI SeQueryInformationToken(PACCESS_TOKEN token, TOKEN_INFORMATION_CLASS class, void *out)
+NTSTATUS WINAPI SeQueryInformationToken(PACCESS_TOKEN token, TOKEN_INFORMATION_CLASS class, void **out)
 {
-    FIXME("%p %#x %p stub!\n", token, class, out);
+    const ULONG length = 0x500;
+    TRACE("%p %#x %p\n", token, class, out);
 
-    return STATUS_NOT_IMPLEMENTED;
+    if (!out) return STATUS_INVALID_PARAMETER;
+    if (!token) return STATUS_INVALID_PARAMETER;
+
+    /* FIXME: just allocate some big buffer for now */
+    *out = ExAllocatePool(PagedPool, length);
+
+    if (!*out) return STATUS_NO_MEMORY;
+
+    return NtQueryInformationToken(token->handle, class, *out, length, NULL);
 }
 
 /***********************************************************************
@@ -3914,7 +3950,11 @@ NTSTATUS WINAPI SeQueryInformationToken(PACCESS_TOKEN token, TOKEN_INFORMATION_C
  */
 void WINAPI ProbeForRead(void *address, SIZE_T length, ULONG alignment)
 {
-    FIXME("(%p %Iu %lu) stub\n", address, length, alignment);
+    FIXME("(%p %Iu %lu) semi-stub\n", address, length, alignment);
+
+    /* FIXME: is my math right? */
+    if ((ULONG_PTR)address & (alignment-1))
+        RtlRaiseStatus(STATUS_DATATYPE_MISALIGNMENT);
 }
 
 /***********************************************************************
@@ -3923,7 +3963,7 @@ void WINAPI ProbeForRead(void *address, SIZE_T length, ULONG alignment)
 void WINAPI ProbeForWrite(void *address, SIZE_T length, ULONG alignment)
 {
     volatile char *ptr = address; /* prevent optimization */
-    FIXME("(%p %Iu %lu)\n", address, length, alignment);
+    TRACE("(%p %Iu %lu)\n", address, length, alignment);
 
     /* FIXME: is my math right? */
     if ((ULONG_PTR)address & (alignment-1))
@@ -4562,7 +4602,8 @@ static const WCHAR token_type_name[] = {'T','o','k','e','n',0};
 
 static struct _OBJECT_TYPE token_type =
 {
-    token_type_name
+    token_type_name,
+    create_token_object
 };
 
 POBJECT_TYPE SeTokenObjectType = &token_type;
diff --git a/dlls/ntoskrnl.exe/ntoskrnl_private.h b/dlls/ntoskrnl.exe/ntoskrnl_private.h
index 3c232dc7765..c14ea415d1d 100644
--- a/dlls/ntoskrnl.exe/ntoskrnl_private.h
+++ b/dlls/ntoskrnl.exe/ntoskrnl_private.h
@@ -58,6 +58,7 @@ struct _EPROCESS
     BOOL wow64;
     DWORD session_id;
     char imageName[256]; /* image file name */
+    void *token;
 };
 
 struct _KTHREAD
diff --git a/include/winnt.h b/include/winnt.h
index 7e6f8fcc684..1d2a90f6b56 100644
--- a/include/winnt.h
+++ b/include/winnt.h
@@ -4184,8 +4184,15 @@ typedef struct tagMESSAGE_RESOURCE_DATA {
 
 #define ANYSIZE_ARRAY   1
 
+/* generic token object. Not windows compatible fs */
+typedef struct _TOKEN
+{
+    HANDLE handle;
+} TOKEN, *PTOKEN;
+
+typedef PTOKEN PACCESS_TOKEN;
+
 /* FIXME:  Orphan.  What does it point to? */
-typedef PVOID PACCESS_TOKEN;
 typedef PVOID PSECURITY_DESCRIPTOR;
 typedef PVOID PSID;
 
